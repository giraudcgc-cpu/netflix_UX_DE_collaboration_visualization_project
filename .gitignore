# =========================
# DATA ENGINEERING
# =========================

# --- Keep folder structure visible ---
!data/
!data/README.md
!data/.gitkeep

# --- Ignore raw / external data ---
data/raw/
data/external/

# --- Ignore large processed outputs ---
data/processed/*.parquet
data/processed/*.csv

# --- Allow small sample datasets (optional) ---
!data/processed/sample_*.csv
!data/processed/sample_*.parquet

# --- Local analytical databases ---
database/
*.duckdb

# =========================
# OPTIONAL (if needed)
# =========================
*.log